      layoutRootPaths.1 = EXT:xm_formcycle/Resources/Private/Layouts/
      layoutRootPaths.2 = {$plugin.tx_xmformcycle.view.layoutRootPath}
      templateName = Formcycle
      dataProcessing {
        1781791186 = Xima\XmFormcycle\DataProcessing\FormListProcessor
        1781861931 = site
        1781861931 {
          as = site
        }
      }
    }
  }
}

formcycle_ajax = PAGE
formcycle_ajax.typeNum = 1464705954

// handle record links
config.recordLinks.formcycleForm {
    forceLink = 0
    typolink {
        parameter = {$formcycle.detailPid}
        additionalParams.data = field:id
        additionalParams.wrap = &xfc_form=|
    }
}
